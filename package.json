{
  "name": "coaching-mcp",
  "version": "1.3.0",
  "description": "Personal coaching MCP server backed by SQLite+FTS5 — serves SKILL.md knowledge to Claude AI",
  "keywords": [
    "claude",
    "coaching",
    "fts5",
    "mcp",
    "sqlite"
  ],
  "license": "MIT",
  "bin": {
    "coaching-mcp": "dist/index.js",
    "coaching-mcp-restore": "dist/restore-cli.js",
    "coaching-mcp-snapshot": "dist/snapshot-cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/index.ts",
    "snapshot": "node dist/snapshot-cli.js",
    "restore": "node dist/restore-cli.js",
    "test": "vitest run",
    "check": "oxlint . && oxfmt . --check",
    "check:fix": "oxlint . && oxfmt . --write",
    "check:types": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.70.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=26.0.0"
  }
}
